---
import Terminal from "./Terminal.astro";
---

<section id="output" data-reveal class="border-t border-white/5 py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid items-center gap-14 lg:grid-cols-2">
      <div class="order-2 min-w-0 lg:order-1">
        <Terminal title="jobs/seaport-<run-id>/">
<span class="text-foam-300">jobs/seaport-&lt;run-id&gt;/</span>
├── config.json
├── result.json        <span class="text-neutral-500"># pass/fail counts, avg reward</span>
└── <span class="text-foam-300">&lt;task-name&gt;/</span>
    ├── config.json
    ├── result.json
    ├── agent/
    │   └── trajectory.json   <span class="text-neutral-500"># command, exit, stdout/err</span>
    └── verifier/
        ├── reward.txt
        ├── test-stdout.txt
        └── test-stderr.txt
        </Terminal>
      </div>

      <div class="order-1 lg:order-2">
        <p class="text-sm font-semibold uppercase tracking-widest text-foam-400">
          Results
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          See exactly what happened
        </h2>
        <p class="mt-4 text-lg text-neutral-400">
          Get a clean pass rate at a glance, and a full record of every attempt
          when you want to dig in. It's all plain JSON, so you can drop it into a dashboard,
          a spreadsheet, or your CI pipeline and watch your agent improve.
        </p>

        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-3">
          <div class="rounded-xl border border-white/10 bg-white/[0.02] p-4">
            <div class="text-2xl font-bold text-white">Pass rate</div>
            <div class="mt-1 text-xs text-neutral-500">at a glance</div>
          </div>
          <div class="rounded-xl border border-white/10 bg-white/[0.02] p-4">
            <div class="text-2xl font-bold text-white">Full logs</div>
            <div class="mt-1 text-xs text-neutral-500">of every attempt</div>
          </div>
          <div class="rounded-xl border border-white/10 bg-white/[0.02] p-4">
            <div class="text-2xl font-bold text-white">Plain JSON</div>
            <div class="mt-1 text-xs text-neutral-500">CI-ready</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
