---
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<div
  data-terminal
  class="w-full min-w-0 max-w-full overflow-hidden rounded-xl bg-ink-900/80 shadow-2xl shadow-black/40"
>
  <div
    class="flex items-center gap-2 bg-ink-800/60 px-4 py-2.5"
  >
    <span class="h-3 w-3 rounded-full bg-[#ff5f56]"></span>
    <span class="h-3 w-3 rounded-full bg-[#ffbd2e]"></span>
    <span class="h-3 w-3 rounded-full bg-[#27c93f]"></span>
    {title && <span class="ml-3 font-mono text-xs text-neutral-500">{title}</span>}
    <button type="button" class="copy-btn ml-auto" aria-label="Copy to clipboard">
      <svg class="ico-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="9" y="9" width="11" height="11" rx="2"></rect>
        <path d="M5 15V5a2 2 0 0 1 2-2h10"></path>
      </svg>
      <svg class="ico-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 6 9 17l-5-5"></path>
      </svg>
    </button>
  </div>
  <pre
    class="overflow-x-auto px-5 py-4 font-mono text-[13px] leading-relaxed text-neutral-200"><code><slot /></code></pre>
</div>
