---
import Terminal from "./Terminal.astro";

const steps = [
  {
    n: "01",
    title: "Describe the task",
    body: "Write what the agent should do and a quick test that checks if it nailed it. That's the whole setup.",
  },
  {
    n: "02",
    title: "Choose your agent",
    body: "Plug in Claude Code, Codex, or your own. Want a baseline? Seaport can run the known-good solution to sanity-check the task itself.",
  },
  {
    n: "03",
    title: "Let it run",
    body: "Seaport spins up a clean, isolated environment, hands the task to your agent, and grades the result. Totally hands-off.",
  },
  {
    n: "04",
    title: "Read the score",
    body: "Get a clear pass rate plus a full transcript of what your agent tried, so you know not just if it failed, but why.",
  },
];
---

<section id="workflow" data-reveal class="border-t border-white/5 py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid items-start gap-14 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest text-foam-400">
          Workflow
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          From idea to score in four steps
        </h2>
        <p class="mt-4 text-lg text-neutral-400">
          No new framework to learn. If you've written a shell script, you
          already know how to use Seaport.
        </p>

        <ol class="mt-10 space-y-7">
          {
            steps.map((step) => (
              <li class="flex gap-5">
                <span class="font-mono text-sm font-medium text-foam-400/80">
                  {step.n}
                </span>
                <div>
                  <h3 class="font-semibold text-white">{step.title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-neutral-400">
                    {step.body}
                  </p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="min-w-0 space-y-5">
        <Terminal title="hello-world/">
<span class="text-foam-300">hello-world/</span>
├── instruction.md     <span class="text-neutral-500"># the prompt given to the agent</span>
├── task.toml          <span class="text-neutral-500"># metadata, timeouts, environment</span>
├── environment/
│   └── Dockerfile
├── solution/
│   └── solve.sh       <span class="text-neutral-500"># used by the oracle agent</span>
└── tests/
    └── test.sh        <span class="text-neutral-500"># writes reward.txt: 1 or 0</span>
        </Terminal>

        <Terminal title="task.toml">
<span class="text-foam-300">[task]</span>
name = <span class="text-tide-400">"acme/hello-world"</span>
description = <span class="text-tide-400">"Create the expected output file."</span>

<span class="text-foam-300">[environment]</span>
docker_image = <span class="text-tide-400">"ubuntu:24.04"</span>
network_mode = <span class="text-tide-400">"no-network"</span>
build_timeout_sec = <span class="text-tide-400">600.0</span>
        </Terminal>
      </div>
    </div>
  </div>
</section>
