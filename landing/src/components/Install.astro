---
import Terminal from "./Terminal.astro";
import StarButton from "./StarButton.astro";
---

<section id="install" data-reveal class="border-t border-white/5 py-24">
  <div class="mx-auto max-w-4xl px-6 text-center">
    <p class="text-sm font-semibold uppercase tracking-widest text-foam-400">
      Get started
    </p>
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
      Your first eval, in two minutes
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-neutral-400">
      One line to install, one line to run.
    </p>

    <div class="mx-auto mt-10 max-w-2xl text-left">
      <Terminal>
<span class="text-tide-400">curl</span> -fsSL https://seaport.run/install.sh | bash
      </Terminal>
    </div>

    <div class="mt-10 flex flex-col items-center justify-center gap-4">
      <div class="flex w-full flex-col items-center justify-center gap-3 sm:w-auto sm:flex-row">
        <StarButton variant="primary" class="w-full sm:w-auto" />
        <a
          href="/docs/getting-started"
          class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-white/5 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/10 sm:w-auto"
        >
          Get started
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
      <span class="text-sm text-neutral-500"
        >Works on macOS, Linux, and Windows</span
      >
    </div>
  </div>
</section>
